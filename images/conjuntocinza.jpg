            <script>
                 // v14.5.8+ 支持 WingBase/getDPInfo，结果存入 window.__wingDPInfoSwiftSsr 供 params 复用
                 // 不覆盖 writeHead1 早期脚本已设置的值，防止重复发起 postBridge 或重置已有数据
                 if (window.__wingDPInfoSwiftSsr === undefined) window.__wingDPInfoSwiftSsr = null
                 window.__wingFetchStarted = window.__wingFetchStarted || false
                 window.__wingTimerStarted = window.__wingTimerStarted || false
                 function fetchDPInfo() {
                    try {
                        if (window.__ssrAppVersionNum < 1458) return
                        if (window.__wingFetchStarted) return
                        if (!window.__wingTimerStarted) {
                            // Wing SDK 还未就绪，轮询等待（每 100ms 一次，最多 20 次即 2s）
                            window.__wingTimerStarted = true
                            var retryCount = 0
                            var timer = setInterval(function() {
                                if (window.Wing && window.Wing.postBridge) {
                                    clearInterval(timer)
                                    window.__wingFetchStarted = true
                                    window.Wing.postBridge('WingBase/getDPInfo', { keys: ['launch_source', 'is_coldlaunch'] }, 1000)
                                        .then(function(res) { window.__wingDPInfoSwiftSsr = res || {} })
                                        .catch(function() { window.__wingDPInfoSwiftSsr = {} })
                                } else if (++retryCount >= 20) {
                                    clearInterval(timer)
                                }
                            }, 100)
                        }
                    } catch (e) {}
                 }

                 fetchDPInfo()

                 window.monitorLight = clientMonitorLight.createMonitor({
                        device_type: 'pc',
                        language: 'pt-br',
                        currency: 'BRL',
                        uemId: '9c26ecf5-63d9-589a-a5de-55487193fe4c',
                        server_type: 'central',
                        env: 'production',
                        site_uid: 'br',
                        ignore_error: [/Script error/i, (tag) => tag === 'web_resource_error' && Math.random() > 0.2],
                        white_screen: {
                        roots: ['html', 'body', '#app'],
                        time: 3000,
                        ssr: true,
                    },
                    fields: {
                        member_id: () => '',
                        params() {
                            var dpInfo = window.__wingDPInfoSwiftSsr
                            var dpAvail = dpInfo && Object.keys(dpInfo).length > 0
                            return {
                                deviceid: '47D0318E_7518_0244_AADF_D2A2FEEB328D',
                                page_id: '3715',
                                site_uid: 'br',
                                page_name: 'page_ark_production_918',
                                server_from: 'web-swift',
                                launch_source: !dpAvail ? 'unknown' : (dpInfo.launch_source || '0'),
                                is_coldlaunch: !dpAvail ? 'unknown' : (dpInfo.is_coldlaunch || '0'),
                            }
                        },
                    },
                });
            </script>
        
    
