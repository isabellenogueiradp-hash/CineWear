          <!-- 懒加载初始化 -->
          <script>
              window.onload = function () {
                  // 在浏览器空闲时初始化 resourceSDK（低优先级）
                  (window.requestIdleCallback || window.requestUserIdle || setTimeout)(function() {
                      if (typeof resourceSDK !== 'undefined') {
                          var config = window.gbCommonInfo && window.gbCommonInfo.RESOURCE_SDK || {};
                          resourceSDK({ isSupprotCut: true, avifEnabled: !!config.isAvifGated });
                      }
                  });

                  //禁止双击页面缩放
                  var lastTouchEnd = 0
                  document.addEventListener(
                      'touchstart',
                      function (event) {
                          if (event.touches.length > 1) {
                              event.preventDefault()
                          }
                      },
                      { passive: false },
                  )
                  document.addEventListener(
                      'touchend',
                      function (event) {
                          var now = new Date().getTime()
                          if (now - lastTouchEnd <= 300) {
                              event.preventDefault()
                          }
                          lastTouchEnd = now
                      },
                      { passive: false },
                  )

                  // 阻止双指放大
                  document.addEventListener('gesturestart', function (event) {
                      event.preventDefault()
                  })
              }
              window.receiveUserInfo = function () {}
              window.mobileToWebPauseAudio = function () {}
              window.mobileToWebResumeAudio = function () {}
              window.getNotifyStatusFromSetting = function () {}
              window.getAddCartCountFromApp = function () {}
              window.extraFontFamily= "MiddleEast-Regular,Roboto,Helvetica,Arial,sans-serif"
